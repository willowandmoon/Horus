generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String               @id @default(uuid()) @db.Uuid
  email                 String               @unique
  passwordHash          String               @map("password_hash")
  nfcTagId              String?              @unique @map("nfc_tag_id")
  accountStatus         AccountStatus        @default(ACTIVE) @map("account_status")
  lastLogin             DateTime?            @map("last_login")
  pushToken             String?              @map("push_token")
  healthReportEnabled   Boolean              @default(true) @map("health_report_enabled")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  allergies             Allergy[]
  chronicConditions     ChronicCondition[]
  emergencyAlerts       EmergencyAlert[]
  emergencyContacts     EmergencyContact[]
  medicalHistory        MedicalHistory[]
  medicalProfile        MedicalProfile?
  profileScans          ProfileScan[]
  personalInfo          PersonalInformation?
  privacySettings       PrivacySettings?
  medications           UserMedication[]
  orders                Order[]
  payments              Payment[]
  subscriptions         Subscription[]
  deviceLoginCodes      DeviceLoginCode[]
  deviceSessions        DeviceSession[]
  securityLogs          SecurityLog[]
  userDevices           UserDevice[]

  @@map("users")
}

model UserDevice {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  type         UserDeviceType
  identifier   String?
  registeredAt DateTime       @default(now()) @map("registered_at")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_devices")
}

model DeviceLoginCode {
  id        String   @id @default(uuid()) @db.Uuid
  codeHash  String   @map("code_hash")
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("device_login_codes")
}

model DeviceSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  deviceName   String?  @map("device_name")
  deviceModel  String?  @map("device_model")
  osVersion    String?  @map("os_version")
  isActive     Boolean  @default(true) @map("is_active")
  lastActive   DateTime @default(now()) @map("last_active")
  refreshToken String?  @unique @map("refresh_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("device_sessions")
}

model SecurityLog {
  id        String   @id @default(uuid()) @db.Uuid
  eventType String   @map("event_type")
  ipAddress String?  @map("ip_address")
  details   Json?
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("security_logs")
}

model PersonalInformation {
  id                   String     @id @default(uuid()) @db.Uuid
  userId               String     @unique @map("user_id") @db.Uuid
  firstName            String     @map("first_name")
  lastName             String     @map("last_name")
  dateOfBirth          DateTime?  @map("date_of_birth") @db.Date
  gender               Gender?
  bloodType            BloodType? @map("blood_type")
  identificationNumber String?    @unique @map("identification_number")
  identificationType   String?    @map("identification_type")
  photoUrl             String?    @map("photo_url")
  phone                String?
  location             String?
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personal_information")
}

model MedicalProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  heightCm          Decimal? @map("height_cm") @db.Decimal(5, 2)
  weightKg          Decimal? @map("weight_kg") @db.Decimal(5, 2)
  organDonor        Boolean  @default(false) @map("organ_donor")
  insuranceProvider String?  @map("insurance_provider")
  additionalNotes   String?  @map("additional_notes")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_profile")
}

model Allergy {
  id                  String          @id @default(uuid()) @db.Uuid
  userId              String          @map("user_id") @db.Uuid
  allergenName        String          @map("allergen_name")
  allergyType         AllergyType     @map("allergy_type")
  severity            AllergySeverity
  reactionDescription String?         @map("reaction_description")
  diagnosedDate       DateTime?       @map("diagnosed_date") @db.Date
  isActive            Boolean         @default(true) @map("is_active")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, severity])
  @@map("allergies")
}

model ChronicCondition {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  conditionName String             @map("condition_name")
  diagnosedDate DateTime?          @map("diagnosed_date") @db.Date
  severity      ConditionSeverity?
  status        ConditionStatus    @default(ACTIVE)
  notes         String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("chronic_conditions")
}

model MedicationCatalog {
  id              String           @id @default(uuid()) @db.Uuid
  genericName     String           @unique @map("generic_name")
  commonDosages   Json?            @map("common_dosages")
  createdAt       DateTime         @default(now()) @map("created_at")
  userMedications UserMedication[]

  @@index([genericName])
  @@map("medication_catalog")
}

model UserMedication {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @map("user_id") @db.Uuid
  medicationId         String?            @map("medication_id") @db.Uuid
  customMedicationName String?            @map("custom_medication_name")
  dosage               String?
  frequency            String?
  route                MedicationRoute    @default(ORAL)
  startDate            DateTime?          @map("start_date") @db.Date
  endDate              DateTime?          @map("end_date") @db.Date
  isCurrent            Boolean            @default(true) @map("is_current")
  purpose              String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  medication           MedicationCatalog? @relation(fields: [medicationId], references: [id])
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isCurrent])
  @@map("user_medications")
}

model EmergencyContact {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  fullName       String   @map("full_name")
  relationship   String
  phonePrimary   String   @map("phone_primary")
  phoneSecondary String?  @map("phone_secondary")
  email          String?
  priorityOrder  Int      @default(1) @map("priority_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, priorityOrder])
  @@map("emergency_contacts")
}

model MedicalHistory {
  id        String                  @id @default(uuid()) @db.Uuid
  userId    String                  @map("user_id") @db.Uuid
  eventType MedicalHistoryEventType @map("event_type")
  eventName String                  @map("event_name")
  eventDate DateTime?               @map("event_date") @db.Date
  location  String?
  provider  String?
  outcome   String?
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime                @updatedAt @map("updated_at")
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@map("medical_history")
}

enum ScanType {
  NFC
  QR
}

model ProfileScan {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  scanType          ScanType @default(NFC) @map("scan_type")
  scanTimestamp     DateTime @default(now()) @map("scan_timestamp")
  scannerIp         String?  @map("scanner_ip")
  scannerDeviceInfo Json?    @map("scanner_device_info")
  accessGranted     Boolean  @default(true) @map("access_granted")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scanTimestamp(sort: Desc)])
  @@map("profile_scans")
}

model EmergencyAlert {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  alertTimestamp DateTime    @default(now()) @map("alert_timestamp")
  status         AlertStatus @default(ACTIVE)
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, alertTimestamp(sort: Desc)])
  @@map("emergency_alerts")
}

model PrivacySettings {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  showFullName          Boolean  @default(true) @map("show_full_name")
  showPhoto             Boolean  @default(true) @map("show_photo")
  showAge               Boolean  @default(true) @map("show_age")
  showBloodType         Boolean  @default(true) @map("show_blood_type")
  showMedicalHistory    Boolean  @default(true) @map("show_medical_history")
  showMedications       Boolean  @default(true) @map("show_medications")
  showAllergies         Boolean  @default(true) @map("show_allergies")
  showEmergencyContacts Boolean  @default(true) @map("show_emergency_contacts")
  showChronicConditions Boolean  @default(true) @map("show_chronic_conditions")
  requireAuthentication Boolean  @default(false) @map("require_authentication")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

model Product {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @unique
  productType   ProductType    @map("product_type")
  description   String?        @db.Text
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("COP")
  isActive      Boolean        @default(true) @map("is_active")
  billingCycle  String         @default("ANNUAL") @map("billing_cycle")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  orders        Order[]
  subscriptions Subscription[]

  @@map("products")
}

model Order {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  productId          String        @map("product_id") @db.Uuid
  reference          String        @unique
  status             OrderStatus   @default(PENDING)
  totalAmount        Decimal       @map("total_amount") @db.Decimal(10, 2)
  currency           String        @default("COP")
  shippingFullName     String?       @map("shipping_full_name")
  shippingPhone        String?       @map("shipping_phone")
  shippingStreet       String        @map("shipping_street")
  shippingNeighborhood String?       @map("shipping_neighborhood")
  shippingCity         String        @map("shipping_city")
  shippingDepartment   String        @map("shipping_department")
  shippingZip          String?       @map("shipping_zip")
  shippingInstructions String?       @map("shipping_instructions")
  braceletColor      String?       @map("bracelet_color")
  cardFrontUrl       String?       @map("card_front_url")
  cardBackUrl        String?       @map("card_back_url")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  user               User          @relation(fields: [userId], references: [id])
  product            Product       @relation(fields: [productId], references: [id])
  payment            Payment?
  subscription       Subscription?

  @@index([userId, status])
  @@index([reference])
  @@map("orders")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  orderId         String        @unique @map("order_id") @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  mpTransactionId String?       @unique @map("mp_transaction_id")
  mpReference     String?       @map("mp_reference")
  paymentMethod   PaymentMethod @map("payment_method")
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("COP")
  mpResponse      Json?         @map("mp_response")
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  order           Order         @relation(fields: [orderId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([mpTransactionId])
  @@index([status, createdAt(sort: Desc)])
  @@map("payments")
}

model Subscription {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @map("user_id") @db.Uuid
  orderId               String?            @unique @map("order_id") @db.Uuid
  productId             String             @map("product_id") @db.Uuid
  status                SubscriptionStatus @default(PENDING)
  startDate             DateTime?          @map("start_date")
  endDate               DateTime?          @map("end_date")
  cancelledAt           DateTime?          @map("cancelled_at")
  autoRenew             Boolean            @default(true) @map("auto_renew")
  renewalReminderSentAt DateTime?          @map("renewal_reminder_sent_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  user                  User               @relation(fields: [userId], references: [id])
  product               Product            @relation(fields: [productId], references: [id])
  order                 Order?             @relation(fields: [orderId], references: [id])

  @@index([userId, status])
  @@index([endDate])
  @@map("subscriptions")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum AllergyType {
  MEDICATION
  FOOD
  ENVIRONMENTAL
  OTHER
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
}

enum ConditionStatus {
  ACTIVE
  MANAGED
  IN_REMISSION
  RESOLVED
}

enum ConditionSeverity {
  MILD
  MODERATE
  SEVERE
}

enum MedicationRoute {
  ORAL
  INJECTION
  TOPICAL
  INHALATION
  OTHER
}

enum MedicalHistoryEventType {
  SURGERY
  HOSPITALIZATION
  VACCINATION
  INJURY
  OTHER
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  FALSE_ALARM
}

enum ProductType {
  BRACELET
  CARD
}

enum UserDeviceType {
  BRACELET
  SMARTWATCH
  CARD
}

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
  VOIDED
  ERROR
}

enum PaymentMethod {
  CARD
  PSE
  NEQUI
  BANCOLOMBIA_TRANSFER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}
