generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String               @id @default(uuid()) @db.Uuid
  email             String               @unique
  passwordHash      String               @map("password_hash")
  nfcTagId          String?              @unique @map("nfc_tag_id")
  accountStatus     AccountStatus        @default(ACTIVE) @map("account_status")
  lastLogin         DateTime?            @map("last_login")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  allergies         Allergy[]
  chronicConditions ChronicCondition[]
  emergencyAlerts   EmergencyAlert[]
  emergencyContacts EmergencyContact[]
  medicalHistory    MedicalHistory[]
  medicalProfile    MedicalProfile?
  nfcScans          NfcScan[]
  personalInfo      PersonalInformation?
  privacySettings   PrivacySettings?
  medications       UserMedication[]
  orders            Order[]
  payments          Payment[]
  subscriptions     Subscription[]

  @@map("users")
}

model PersonalInformation {
  id                   String     @id @default(uuid()) @db.Uuid
  userId               String     @unique @map("user_id") @db.Uuid
  firstName            String     @map("first_name")
  lastName             String     @map("last_name")
  dateOfBirth          DateTime?  @map("date_of_birth") @db.Date
  gender               Gender?
  bloodType            BloodType? @map("blood_type")
  identificationNumber String?    @unique @map("identification_number")
  identificationType   String?    @map("identification_type")
  photoUrl             String?    @map("photo_url")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personal_information")
}

model MedicalProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  heightCm          Decimal? @map("height_cm") @db.Decimal(5, 2)
  weightKg          Decimal? @map("weight_kg") @db.Decimal(5, 2)
  organDonor        Boolean  @default(false) @map("organ_donor")
  insuranceProvider String?  @map("insurance_provider")
  additionalNotes   String?  @map("additional_notes")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_profile")
}

model Allergy {
  id                  String          @id @default(uuid()) @db.Uuid
  userId              String          @map("user_id") @db.Uuid
  allergenName        String          @map("allergen_name")
  allergyType         AllergyType     @map("allergy_type")
  severity            AllergySeverity
  reactionDescription String?         @map("reaction_description")
  diagnosedDate       DateTime?       @map("diagnosed_date") @db.Date
  isActive            Boolean         @default(true) @map("is_active")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, severity])
  @@map("allergies")
}

model ChronicCondition {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  conditionName String             @map("condition_name")
  diagnosedDate DateTime?          @map("diagnosed_date") @db.Date
  severity      ConditionSeverity?
  status        ConditionStatus    @default(ACTIVE)
  notes         String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("chronic_conditions")
}

model MedicationCatalog {
  id              String           @id @default(uuid()) @db.Uuid
  genericName     String           @unique @map("generic_name")
  commonDosages   Json?            @map("common_dosages")
  createdAt       DateTime         @default(now()) @map("created_at")
  userMedications UserMedication[]

  @@index([genericName])
  @@map("medication_catalog")
}

model UserMedication {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @map("user_id") @db.Uuid
  medicationId         String?            @map("medication_id") @db.Uuid
  customMedicationName String?            @map("custom_medication_name")
  dosage               String?
  frequency            String?
  route                MedicationRoute    @default(ORAL)
  startDate            DateTime?          @map("start_date") @db.Date
  endDate              DateTime?          @map("end_date") @db.Date
  isCurrent            Boolean            @default(true) @map("is_current")
  purpose              String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  medication           MedicationCatalog? @relation(fields: [medicationId], references: [id])
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isCurrent])
  @@map("user_medications")
}

model EmergencyContact {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  fullName       String   @map("full_name")
  relationship   String
  phonePrimary   String   @map("phone_primary")
  phoneSecondary String?  @map("phone_secondary")
  email          String?
  priorityOrder  Int      @default(1) @map("priority_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, priorityOrder])
  @@map("emergency_contacts")
}

model MedicalHistory {
  id        String                  @id @default(uuid()) @db.Uuid
  userId    String                  @map("user_id") @db.Uuid
  eventType MedicalHistoryEventType @map("event_type")
  eventName String                  @map("event_name")
  eventDate DateTime?               @map("event_date") @db.Date
  location  String?
  provider  String?
  outcome   String?
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime                @updatedAt @map("updated_at")
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@map("medical_history")
}

model NfcScan {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  scanTimestamp     DateTime @default(now()) @map("scan_timestamp")
  scannerIp         String?  @map("scanner_ip")
  scannerDeviceInfo Json?    @map("scanner_device_info")
  accessGranted     Boolean  @default(true) @map("access_granted")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scanTimestamp(sort: Desc)])
  @@map("nfc_scans")
}

model EmergencyAlert {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  alertTimestamp DateTime    @default(now()) @map("alert_timestamp")
  status         AlertStatus @default(ACTIVE)
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, alertTimestamp(sort: Desc)])
  @@map("emergency_alerts")
}

model PrivacySettings {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  showFullName          Boolean  @default(true) @map("show_full_name")
  showPhoto             Boolean  @default(true) @map("show_photo")
  showAge               Boolean  @default(true) @map("show_age")
  showBloodType         Boolean  @default(true) @map("show_blood_type")
  showMedicalHistory    Boolean  @default(true) @map("show_medical_history")
  showMedications       Boolean  @default(true) @map("show_medications")
  showAllergies         Boolean  @default(true) @map("show_allergies")
  showEmergencyContacts Boolean  @default(true) @map("show_emergency_contacts")
  requireAuthentication Boolean  @default(false) @map("require_authentication")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum AllergyType {
  MEDICATION
  FOOD
  ENVIRONMENTAL
  OTHER
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
}

enum ConditionStatus {
  ACTIVE
  MANAGED
  IN_REMISSION
  RESOLVED
}

enum ConditionSeverity {
  MILD
  MODERATE
  SEVERE
}

enum MedicationRoute {
  ORAL
  INJECTION
  TOPICAL
  INHALATION
  OTHER
}

enum MedicalHistoryEventType {
  SURGERY
  HOSPITALIZATION
  VACCINATION
  INJURY
  OTHER
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  FALSE_ALARM
}

// ============================================================
// ENUM: nuevos para pagos
// ============================================================

enum ProductType {
  BRACELET // manilla física
  CARD // tarjeta física
}

enum OrderStatus {
   PENDING // orden creada, esperando pago
   PAYMENT_PENDING // en proceso de pago
   PAID // pago confirmado por MercadoPago
   PROCESSING // preparando envío
   SHIPPED // enviado
   DELIVERED // entregado
   CANCELLED // cancelado
   REFUNDED // reembolsado
}

enum PaymentStatus {
   PENDING // esperando respuesta de MercadoPago
   APPROVED // pago aprobado
   DECLINED // pago rechazado
   VOIDED // anulado
   ERROR // error en el proceso
}

enum PaymentMethod {
  CARD // tarjeta crédito/débito
  PSE // transferencia bancaria
  NEQUI // Nequi
  BANCOLOMBIA_TRANSFER
}

enum SubscriptionStatus {
  ACTIVE // suscripción vigente
  EXPIRED // venció
  CANCELLED // cancelada por el usuario
  PENDING // esperando primer pago
}

// ============================================================
// TABLA: products
// Catálogo de productos (manilla y tarjeta)
// ============================================================

model Product {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @unique //"Horus Bracelet", "Horus Card"
  productType ProductType @map("product_type")
  description String?     @db.Text
  price       Decimal     @db.Decimal(10, 2) // precio en COP
  currency    String      @default("COP")
  isActive    Boolean     @default(true) @map("is_active")

  // Suscripción anual
  billingCycle String @default("ANNUAL") @map("billing_cycle")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders        Order[]
  subscriptions Subscription[]

  @@map("products")
}

// ============================================================
// TABLA: orders
// Orden de compra — antes del pago
// ============================================================

model Order {
   id        String @id @default(uuid()) @db.Uuid
   userId    String @map("user_id") @db.Uuid
   productId String @map("product_id") @db.Uuid

   // Referencia única para MercadoPago
   reference String @unique // "horus-1234567890"

  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  currency    String      @default("COP")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  user         User          @relation(fields: [userId], references: [id])
  product      Product       @relation(fields: [productId], references: [id])
  payment      Payment?
  subscription Subscription?

  @@index([userId, status])
  @@index([reference])
  @@map("orders")
}

// ============================================================
// TABLA: payments
// Registro de cada intento de pago con MercadoPago
// ============================================================

model Payment {
  id      String @id @default(uuid()) @db.Uuid
  orderId String @unique @map("order_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid

  // Datos de MercadoPago
  mpTransactionId String?       @unique @map("mp_transaction_id")
  mpReference     String?       @map("mp_reference")
  paymentMethod      PaymentMethod @map("payment_method")
  status             PaymentStatus @default(PENDING)

  // Montos
  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("COP")

  // Respuesta de MercadoPago (JSON completo para auditoría)
  mpResponse Json? @map("mp_response")

  // Timestamps
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relaciones
  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([mpTransactionId])
  @@index([status, createdAt(sort: Desc)])
  @@map("payments")
}

// ============================================================
// TABLA: subscriptions
// Suscripción anual del usuario
// ============================================================

model Subscription {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  orderId   String? @unique @map("order_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid

  status SubscriptionStatus @default(PENDING)

  // Fechas
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date") // startDate + 1 año
  cancelledAt DateTime? @map("cancelled_at")

  // Renovación
  autoRenew             Boolean   @default(true) @map("auto_renew")
  renewalReminderSentAt DateTime? @map("renewal_reminder_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])

  @@index([userId, status])
  @@index([endDate]) // para detectar suscripciones por vencer
  @@map("subscriptions")
}
